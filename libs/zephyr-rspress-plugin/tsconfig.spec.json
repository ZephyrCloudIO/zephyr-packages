{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "types": [
      "@rstest/core/globals", "jest",
      "node"
    ],
    "composite": true,
    "incremental": true
  },
  "include": [
    "rstest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.d.ts",
    "src/internal/__test__/showFiles.spec.ts",
    "src/internal/__test__/walkFiles.spec.ts",
    "src/internal/__test__/buildAsset.spec.ts"
  ],
  "exclude": [
    "dist"
  ]
}
