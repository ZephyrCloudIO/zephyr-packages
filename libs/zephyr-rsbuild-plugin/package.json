    "zephyr-rspack-plugin": "workspace:*"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:rspack",
    "@rslib/core": "catalog:rslib"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0 || ^2.0.0-0"
  }
