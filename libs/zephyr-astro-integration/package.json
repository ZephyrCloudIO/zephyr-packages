{
  "name": "zephyr-astro-integration",
  "version": "1.1.2",
  "description": "Astro integration for Zephyr Cloud deployment and module federation",
  "keywords": [
    "analytics",
    "astro",
    "astro-component",
    "astro-integration",
    "deployment",
    "module-federation",
    "performance",
    "withastro",
    "zephyr"
  ],
  "homepage": "https://github.com/ZephyrCloudIO/zephyr-packages/tree/main/libs/zephyr-astro-integration#readme",
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-astro-integration"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "patch-version": "pnpm version",
    "dev": "rslib build --watch",
    "typecheck": "tsc -b",
    "test": "rstest run"
  },
  "dependencies": {
    "zephyr-agent": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "catalog:rslib",
    "@rstest/core": "catalog:rstest",
    "astro": "catalog:",
    "typescript": "catalog:typescript"
  },
  "peerDependencies": {
    "astro": "catalog:peer-compat"
  }
}
