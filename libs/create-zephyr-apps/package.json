{
  "name": "create-zephyr-apps",
  "version": "1.1.2",
  "description": "A CLI tool to create web applications using Zephyr.",
  "keywords": [
    "create-zephyr-apps",
    "example",
    "template",
    "zephyr",
    "zephyr-apps",
    "zephyr-cli",
    "zephyr-example",
    "zephyr-template"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/create-zephyr-apps"
  },
  "bin": {
    "create-zephyr-apps": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "dev": "rslib build --watch",
    "build": "rslib build",
    "patch-version": "pnpm version",
    "typecheck": "tsc -b"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "chalk-template": "catalog:",
    "terminal-link": "catalog:"
  },
  "devDependencies": {
    "@rslib/core": "catalog:rslib",
    "@types/node": "catalog:typescript",
    "tsx": "catalog:typescript",
    "typescript": "catalog:typescript"
  }
}
