{
  "name": "sample-rspack-application",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "start": "rspack serve --config rspack.config.js --mode development --port 4301",
    "build": "rspack build --config rspack.config.js --mode production",
    "build-watch": "rspack build --config rspack.config.js --mode development --watch"
  },
  "dependencies": {
    "react": "catalog:react18",
    "react-dom": "catalog:react18"
  },
  "devDependencies": {
    "@types/react": "catalog:react18",
    "@types/react-dom": "catalog:react18",
    "@testing-library/react": "catalog:react",
    "@types/jest": "catalog:typescript",
    "@rspack/cli": "catalog:rspack",
    "@rspack/core": "catalog:rspack",
    "@rspack/plugin-react-refresh": "catalog:rspack",
    "zephyr-rspack-plugin": "workspace:*"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ZephyrCloudIO/zephyr-packages.git"
  }
}
