{
  "name": "zephyr-agent",
  "version": "1.1.2",
  "description": "Zephyr plugin agent",
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-agent"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./node-persist": {
      "import": {
        "types": "./dist/lib/node-persist/index.d.mts",
        "default": "./dist/lib/node-persist/index.mjs"
      },
      "require": {
        "types": "./dist/lib/node-persist/index.d.ts",
        "default": "./dist/lib/node-persist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "patch-version": "pnpm version",
    "dev": "rslib build --watch",
    "typecheck": "tsc -b",
    "test": "rstest run",
    "test:deployment": "cross-env ZE_RUN_AGENT_DEPLOYMENT_E2E=true rstest run"
  },
  "dependencies": {
    "@toon-format/toon": "catalog:",
    "axios": "catalog:",
    "axios-retry": "catalog:",
    "debug": "catalog:",
    "eventsource": "catalog:",
    "git-url-parse": "catalog:",
    "https-proxy-agent": "catalog:",
    "is-ci": "catalog:plugin-shared",
    "jiti": "catalog:",
    "jose": "catalog:",
    "node-persist": "catalog:",
    "open": "catalog:",
    "proper-lockfile": "catalog:",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "catalog:rslib",
    "@rstest/core": "catalog:rstest",
    "@types/debug": "catalog:",
    "@types/is-ci": "catalog:typescript",
    "@types/node-persist": "catalog:typescript",
    "@types/proper-lockfile": "catalog:",
    "cross-env": "catalog:",
    "typescript": "catalog:typescript"
  }
}
