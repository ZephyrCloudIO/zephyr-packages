{
  "name": "vite-plugin-vinext-zephyr",
  "version": "0.1.13",
  "description": "Vite plugin for deploying Vinext applications with Zephyr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/vite-plugin-vinext-zephyr"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "patch-version": "pnpm version",
    "prepack": "pnpm build",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "test": "rstest --passWithNoTests",
    "test:coverage": "rstest --coverage --passWithNoTests"
  },
  "dependencies": {
    "tslib": "catalog:typescript",
    "vite": "catalog:vite7",
    "zephyr-agent": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "catalog:typescript",
    "@types/node": "catalog:typescript",
    "@typescript-eslint/eslint-plugin": "catalog:eslint",
    "@rstest/core": "^0.7.7"
  },
  "peerDependencies": {
    "vite": "^7.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
