{
  "name": "zephyr-metro-plugin",
  "version": "1.0.2",
  "description": "Metro bundler plugin for deploying React Native applications with Zephyr Cloud - OTA updates, Module Federation, and seamless deployment",
  "keywords": [
    "android",
    "bundler",
    "cross-platform",
    "deployment",
    "ios",
    "metro",
    "micro-frontends",
    "module-federation",
    "ota",
    "over-the-air",
    "plugin",
    "react-native",
    "zephyr",
    "zephyr-cloud"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-metro-plugin"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "patch-version": "pnpm version",
    "lint": "oxlint src --no-error-on-unmatched-pattern",
    "test": "rstest --passWithNoTests",
    "test:coverage": "rstest --coverage --passWithNoTests"
  },
  "dependencies": {
    "zephyr-agent": "workspace:*",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@rspack/core": "catalog:rspack",
    "@rstest/core": "^0.7.7",
    "@types/find-package-json": "^1.2.6",
    "@types/jest": "catalog:typescript",
    "metro-config": "^0.84.0",
    "metro-transform-worker": "^0.84.0"
  },
  "peerDependencies": {
    "metro": ">=0.70.0",
    "react-native": ">=0.60.0",
    "zephyr-xpack-internal": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "zephyr-xpack-internal": {
      "optional": true
    }
  }
}
