{
  "name": "zephyr-rspress-plugin",
  "version": "1.1.2",
  "description": "Rspress plugin for Zephyr",
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-rspress-plugin"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json",
    "./*": "./*"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "patch-version": "pnpm version",
    "test": "rstest run"
  },
  "dependencies": {
    "zephyr-agent": "workspace:*",
    "zephyr-edge-contract": "workspace:*",
    "zephyr-rsbuild-plugin": "workspace:*",
    "zephyr-xpack-internal": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "catalog:rslib",
    "@rspress/core": "catalog:rspress",
    "@rstest/core": "catalog:rstest",
    "@types/node-persist": "catalog:typescript"
  },
  "peerDependencies": {
    "@rspress/core": "^2.0.0"
  }
}
