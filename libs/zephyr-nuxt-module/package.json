{
  "name": "zephyr-nuxt-module",
  "version": "1.1.2",
  "description": "Nuxt module for deploying Nuxt applications with Zephyr Cloud",
  "keywords": [
    "deployment",
    "edge",
    "module-federation",
    "nuxt",
    "nuxt-module",
    "ssr",
    "zephyr"
  ],
  "homepage": "https://github.com/ZephyrCloudIO/zephyr-packages/tree/main/libs/zephyr-nuxt-module#readme",
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-nuxt-module"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "!dist/**/*.map"
  ],
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "patch-version": "pnpm version",
    "dev": "rslib build --watch",
    "typecheck": "tsc -b",
    "test": "rstest run"
  },
  "dependencies": {
    "zephyr-agent": "workspace:*",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@nuxt/kit": "catalog:nuxt",
    "@nuxt/schema": "catalog:nuxt",
    "@rslib/core": "catalog:rslib",
    "@rstest/core": "catalog:rstest",
    "@types/node": "catalog:typescript",
    "vite": "catalog:vite7"
  },
  "peerDependencies": {
    "@nuxt/kit": "catalog:peer-compat",
    "nuxt": "catalog:peer-compat"
  }
}
