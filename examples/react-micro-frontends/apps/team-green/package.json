{
  "name": "team-green",
  "version": "3.1.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ZephyrCloudIO/zephyr-packages.git"
  },
  "scripts": {
    "build": "rspack build --config rspack.config.js --mode production",
    "start": "rspack serve --config rspack.config.js --mode development --port 4400",
