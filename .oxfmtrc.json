{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "trailingComma": "es5",
  "tabWidth": 2,
  "jsdoc": true,
  "ignorePatterns": [
    "**/dist/**",
    "libs/zephyr-native-cache/lib/**",
    "**/coverage/**",
    "**/.turbo/**",
    "pnpm-lock.yaml",
    "**/*.gen.ts"
  ]
}
