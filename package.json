{
  "name": "zephyr-packages",
  "version": "1.1.2",
  "private": true,
  "license": "Apache-2.0",
  "scripts": {
    "bump-patch": "node scripts/bump-version.js patch",
    "bump-minor": "node scripts/bump-version.js minor",
    "bump-major": "node scripts/bump-version.js major",
    "ze-version-patch": "pnpm --filter './libs/**' patch-version",
    "ze-publish": "pnpm --filter './libs/**' publish --provenance --access public --no-git-checks",
    "build": "turbo run build --filter='./libs/*'",
    "build-all": "turbo run build",
    "build-slow": "turbo run build --concurrency=1 --force",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "turbo run test --filter='./libs/*'",
    "test:examples": "turbo run e2e-test --filter=e2e-deployment --force",
    "prepare": "husky install",
    "test:coverage": "turbo run test --filter='./libs/*' -- --coverage",
    "coverage:merge": "istanbul-merge --out coverage/combined-coverage.json 'coverage/**/coverage-final.json'",
    "coverage:report": "nyc report --reporter=html --temp-directory=coverage --report-dir=coverage/combined",
    "coverage:serve": "serve coverage",
    "remove-all-node-modules": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + ",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "@types/node": "catalog:typescript",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.7",
    "husky": "^9.1.7",
    "nyc": "^17.1.0",
    "oxfmt": "^0.57.0",
    "oxlint": "^1.72.0",
    "serve": "^14.2.5",
    "turbo": "^2.10.2",
    "typescript": "catalog:typescript"
  },
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "packageManager": "pnpm@10.33.1",
  "pnpm": {
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-5c6j-r48x-rmvq"
      ]
    }
  }
}
