{
  "name": "zephyr-rsbuild-plugin",
  "version": "0.1.13",
  "description": "Rsbuild plugin for Zephyr",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-rsbuild-plugin"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsgo -p tsconfig.json",
    "patch-version": "pnpm version",
    "lint": "eslint src --ext .ts,.tsx,.js,.jsx",
    "test": "rstest --passWithNoTests",
    "test:coverage": "rstest --coverage --passWithNoTests"
  },
  "dependencies": {
    "zephyr-rspack-plugin": "workspace:*"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:rspack",
    "@types/jest": "catalog:typescript",
    "@typescript-eslint/eslint-plugin": "catalog:eslint",
    "@rstest/core": "^0.7.7"
  },
  "peerDependencies": {
    "@rsbuild/core": "^1.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
