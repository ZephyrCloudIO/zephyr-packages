{
  "name": "zephyr-agent",
  "version": "1.1.2",
  "description": "Zephyr plugin agent",
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-agent"
  },
  "type": "commonjs",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./node-persist": {
      "import": {
        "types": "./dist/lib/node-persist/index.d.mts",
        "default": "./dist/lib/node-persist/index.mjs"
      },
      "require": {
        "types": "./dist/lib/node-persist/index.d.ts",
        "default": "./dist/lib/node-persist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "rslib build",
    "patch-version": "pnpm version",
    "test": "rstest run",
    "dev": "rslib build --watch"
  },
  "dependencies": {
    "@toon-format/toon": "^0.9.0",
    "axios": "^1.15.0",
    "axios-retry": "^4.5.0",
    "debug": "^4.3.4",
    "eventsource": "^4.0.0",
    "git-url-parse": "^15.0.0",
    "https-proxy-agent": "^7.0.6",
    "is-ci": "catalog:plugin-shared",
    "jose": "^5.10.0",
    "node-persist": "^4.0.1",
    "open": "^10.1.0",
    "proper-lockfile": "^4.1.2",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@rslib/core": "catalog:rslib",
    "@rstest/core": "catalog:rstest",
    "@types/debug": "^4.1.12",
    "@types/eventsource": "^3.0.0",
    "@types/git-url-parse": "^9.0.3",
    "@types/is-ci": "catalog:typescript",
    "@types/node-persist": "catalog:typescript",
    "@types/proper-lockfile": "^4.1.4"
  }
}
