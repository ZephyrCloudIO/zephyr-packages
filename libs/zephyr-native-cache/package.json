{
  "name": "zephyr-native-cache",
  "version": "1.1.2",
  "description": "Native caching module for Module Federation Metro bundles",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-native-cache"
  },
  "source": "src/index.ts",
  "files": [
    "src/",
    "lib/",
    "ios/",
    "android/src/",
    "android/build.gradle",
    "react-native.config.js",
    "zephyr-native-cache.podspec",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/*.spec.ts",
    "!dist/**/*.map",
    "!lib/**/*.map",
    "!lib/**/*.tsbuildinfo"
  ],
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "types": "lib/typescript/index.d.ts",
  "react-native": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./lib/typescript/index.d.ts",
      "import": "./lib/module/index.js",
      "require": "./lib/commonjs/index.js",
      "default": "./lib/commonjs/index.js"
    },
    "./runtime-plugin": {
      "react-native": "./src/runtime-plugin.ts",
      "types": "./lib/typescript/runtime-plugin.d.ts",
      "import": "./lib/module/runtime-plugin.js",
      "require": "./lib/commonjs/runtime-plugin.js",
      "default": "./lib/commonjs/runtime-plugin.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "build": "rslib build",
    "patch-version": "pnpm version",
    "dev": "rslib build --watch",
    "test": "rstest run"
  },
  "dependencies": {
    "mitt": "catalog:",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@module-federation/runtime": "catalog:module-federation",
    "@rslib/core": "catalog:rslib",
    "@rstest/core": "catalog:rstest",
    "@types/react": "catalog:react19",
    "react": "catalog:react19",
    "react-native": "catalog:metro",
    "typescript": "catalog:typescript"
  },
  "peerDependencies": {
    "react": "catalog:peer-compat",
    "react-native": "catalog:peer-native-cache"
  }
}
