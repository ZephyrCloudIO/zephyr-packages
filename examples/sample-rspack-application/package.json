{
  "name": "sample-rspack-application",
  "version": "1.0.0",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/ZephyrCloudIO/zephyr-packages.git"
  },
  "scripts": {
    "start": "rspack serve --mode development",
