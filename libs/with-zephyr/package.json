{
  "name": "with-zephyr",
  "version": "1.1.2",
  "description": "A codemod to automatically add withZephyr plugin to bundler configurations",
  "keywords": [
    "astro",
    "bundler",
    "codemod",
    "metro",
    "modernjs",
    "react-native",
    "rolldown",
    "rollup",
    "rsbuild",
    "rslib",
    "rspack",
    "rspress",
    "vite",
    "webpack",
    "zephyr"
  ],
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/with-zephyr"
  },
  "bin": {
    "with-zephyr": "dist/index.js"
  },
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc -b",
    "test": "rstest run",
    "test:watch": "rstest --watch",
    "test:coverage": "rstest run --coverage"
  },
  "dependencies": {
    "@ast-grep/napi": "catalog:",
    "chalk": "catalog:",
    "commander": "catalog:",
    "glob": "catalog:"
  },
  "devDependencies": {
    "@rslib/core": "catalog:rslib",
    "@rstest/core": "catalog:rstest",
    "@types/node": "catalog:typescript",
    "typescript": "catalog:typescript",
    "zephyr-rsbuild-plugin": "workspace:*"
  }
}
