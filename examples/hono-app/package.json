{
  "name": "hono-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node ../../libs/zephyr-cli/dist/index.js --ssr esbuild src/index.ts --bundle --platform=neutral --outfile=dist/index.js",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "hono": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:typescript",
    "esbuild": "catalog:esbuild",
    "tsx": "catalog:typescript",
    "typescript": "catalog:typescript",
    "vite": "catalog:vite8",
    "zephyr-cli": "workspace:*"
  }
}
