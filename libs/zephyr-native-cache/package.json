{
  "name": "zephyr-native-cache",
  "version": "1.1.2",
  "description": "Native caching module for Module Federation Metro bundles",
  "license": "Apache-2.0",
  "main": "lib/commonjs/index.js",
  "module": "lib/module/index.js",
  "react-native": "src/index.ts",
  "types": "lib/typescript/commonjs/index.d.ts",
  "source": "src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "import": {
        "types": "./lib/typescript/module/index.d.ts",
        "default": "./lib/module/index.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/index.d.ts",
        "default": "./lib/commonjs/index.js"
      },
      "default": "./lib/commonjs/index.js"
    },
    "./runtime-plugin": {
      "react-native": "./src/runtime-plugin.ts",
      "import": {
        "types": "./lib/typescript/module/runtime-plugin.d.ts",
        "default": "./lib/module/runtime-plugin.js"
      },
      "require": {
        "types": "./lib/typescript/commonjs/runtime-plugin.d.ts",
        "default": "./lib/commonjs/runtime-plugin.js"
      },
      "default": "./lib/commonjs/runtime-plugin.js"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-native-cache"
  },
  "scripts": {
    "build": "nx build zephyr-native-cache",
    "prepare": "nx build zephyr-native-cache --skipRemoteCache",
    "test": "pnpm test:unit && pnpm test:package",
    "test:unit": "rstest run --config ../../rstest.config.mts --project zephyr-native-cache",
    "test:package": "node scripts/verify-packed-package.mjs",
    "typecheck": "tsc --noEmit",
    "patch-version": "pnpm version"
  },
  "files": [
    "src/",
    "lib/",
    "ios/",
    "android/src/",
    "android/build.gradle",
    "react-native.config.js",
    "zephyr-native-cache.podspec",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/*.spec.ts"
  ],
  "peerDependencies": {
    "react": ">=19.0.0",
    "react-native": ">=0.79.0"
  },
  "dependencies": {
    "mitt": "^3.0.1",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@babel/core": "catalog:babel",
    "@babel/preset-env": "catalog:babel",
    "@babel/preset-typescript": "catalog:babel",
    "@module-federation/runtime": "^2.3.2",
    "@types/react": "^19.1.0",
    "react": "19.1.0",
    "react-native": "0.80.0",
    "react-native-builder-bob": "0.43.0",
    "typescript": "^5.8.3"
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "exclude": "**/{__tests__/**,__fixtures__/**,__mocks__/**,*.test.*,*.spec.*}",
    "targets": [
      [
        "commonjs",
        {
          "configFile": "./babel.config.cjs",
          "esm": true
        }
      ],
      [
        "module",
        {
          "configFile": "./babel.config.cjs",
          "esm": true
        }
      ],
      "typescript"
    ]
  }
}
