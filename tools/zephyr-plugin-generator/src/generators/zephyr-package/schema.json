{
  "$schema": "http://json-schema.org/schema",
  "cli": "nx",
  "id": "ZephyrPackage",
  "title": "Create a Zephyr Package",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "description": "The name of the package (e.g., 'webpack-plugin', 'vite-plugin')",
      "$default": {
        "$source": "argv",
        "index": 0
      },
      "pattern": "^[a-z][a-z0-9]*(-[a-z0-9]+)*$"
    },
    "directory": {
      "type": "string",
      "description": "Directory where the package will be created",
      "default": "libs"
    },
    "packageType": {
      "type": "string",
      "description": "Type of Zephyr package to create",
      "enum": ["plugin", "agent", "internal", "utility"],
      "default": "plugin"
    },
    "bundler": {
      "type": "string",
      "description": "Target bundler for plugin packages",
      "enum": [
        "webpack",
        "vite",
        "rollup",
        "rspack",
        "parcel",
        "metro",
        "modernjs",
        "rolldown",
        "rsbuild"
      ],
      "default": "webpack"
    },
    "description": {
      "type": "string",
      "description": "Package description"
    },
    "addTests": {
      "type": "boolean",
      "description": "Add test setup",
      "default": true
    }
  },
  "required": ["name"],
  "additionalProperties": false
}
