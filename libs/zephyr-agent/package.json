{
  "name": "zephyr-agent",
  "version": "1.0.2",
  "description": "Zephyr plugin agent",
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/zephyr-agent"
  },
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./node-persist": {
      "import": "./dist/node-persist/index.js",
      "require": "./dist/node-persist/index.js",
      "types": "./dist/node-persist/index.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prebuild": "node -e \"const fs = require('node:fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.rmSync('tsconfig.tsbuildinfo', { force: true })\"",
    "build": "tsgo -p tsconfig.json",
    "patch-version": "pnpm version",
    "test": "rstest --passWithNoTests",
    "lint": "oxlint src --no-error-on-unmatched-pattern",
    "test:coverage": "rstest --coverage --passWithNoTests"
  },
  "dependencies": {
    "@toon-format/toon": "^0.9.0",
    "axios": "^1.15.0",
    "axios-retry": "^4.5.0",
    "debug": "^4.3.4",
    "eventsource": "^4.0.0",
    "git-url-parse": "^15.0.0",
    "https-proxy-agent": "^7.0.6",
    "is-ci": "catalog:plugin-shared",
    "jose": "^5.10.0",
    "node-persist": "^4.0.1",
    "open": "^10.1.0",
    "proper-lockfile": "^4.1.2",
    "tslib": "catalog:typescript",
    "zephyr-edge-contract": "workspace:*"
  },
  "devDependencies": {
    "@rstest/core": "^0.7.7",
    "@types/debug": "^4.1.12",
    "@types/eventsource": "^3.0.0",
    "@types/git-url-parse": "^9.0.3",
    "@types/is-ci": "catalog:typescript",
    "@types/jest": "catalog:typescript",
    "@types/node-persist": "catalog:typescript",
    "@types/proper-lockfile": "^4.1.4"
  }
}
