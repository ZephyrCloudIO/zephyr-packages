{
  "name": "vite-plugin-vinext-zephyr",
  "version": "1.0.2",
  "description": "Vite plugin for deploying Vinext applications with Zephyr",
  "$schema": "https://raw.githubusercontent.com/vitejs/vite-plugin-registry/refs/heads/main/data/schema/extended-package-json.schema.json",
  "keywords": [
    "vite-plugin",
    "vite",
    "vinext",
    "zephyr",
    "deploy"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ZephyrCloudIO/zephyr-packages.git",
    "directory": "libs/vite-plugin-vinext-zephyr"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "ZephyrCloudIO",
    "url": "https://github.com/ZephyrCloudIO"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "nx run vite-plugin-vinext-zephyr:build",
    "patch-version": "pnpm version",
    "prepack": "pnpm build"
  },
  "dependencies": {
    "tslib": "catalog:typescript",
    "vite": "catalog:vite7",
    "zephyr-agent": "workspace:*"
  },
  "devDependencies": {
    "@types/jest": "catalog:typescript",
    "@types/node": "catalog:typescript",
    "@typescript-eslint/eslint-plugin": "catalog:eslint",
    "ts-jest": "catalog:typescript"
  },
  "peerDependencies": {
    "vite": "^7.0.0 || ^8.0.0"
  },
  "compatiblePackages": {
    "schemaVersion": 1,
    "vite": {
      "type": "compatible",
      "versions": "^7.0.0 || ^8.0.0"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "module": "dist/index.js"
}
