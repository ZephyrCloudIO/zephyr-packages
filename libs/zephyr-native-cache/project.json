{
  "name": "zephyr-native-cache",
  "sourceRoot": "libs/zephyr-native-cache/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/lib"],
      "options": {
        "cwd": "libs/zephyr-native-cache",
        "command": "bob build"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["build"],
      "options": {
        "command": "rstest run --config rstest.config.mts --project zephyr-native-cache && node libs/zephyr-native-cache/scripts/verify-packed-package.mjs"
      }
    }
  }
}
