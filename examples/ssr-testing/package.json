{
  "name": "ssr-testing",
  "version": "0.1.0",
  "description": "SSR Testing Infrastructure for Zephyr Module Federation",
  "main": "index.js",
  "scripts": {
    "test": "jest",
    "test:performance": "jest --testMatch='**/*.perf.test.{ts,tsx}'",
    "test:integration": "jest --testMatch='**/*.integration.test.{ts,tsx}'",
    "test:renderer": "jest --testMatch='**/core/renderer/**/*.test.{ts,tsx}'",
    "test:hydration": "jest --testMatch='**/core/hydration/**/*.test.{ts,tsx}'",
    "test:examples": "jest --testMatch='**/integration/**/*.test.{ts,tsx}'",
    "test:environment": "jest --testMatch='**/integration/environment/**/*.test.{ts,tsx}'",
    "test:browser": "jest --testMatch='**/integration/environment/browser-compatibility.test.{ts,tsx}'",
    "generate-reports": "node ./scripts/generate-reports.js",
    "generate-browser-report": "node ./scripts/generate-browser-report.js",
    "ci": "npm test && npm run test:integration && npm run test:performance"
  },
  "keywords": [
    "zephyr",
    "ssr",
    "testing",
    "module-federation"
  ],
  "author": "Zephyr Team",
  "license": "MIT",
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^14.2.1",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "next": "^14.1.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  }
}