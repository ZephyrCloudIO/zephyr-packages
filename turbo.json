{
  "$schema": "https://turborepo.dev/schema.json",
  "remoteCache": {
    "teamSlug": "l727rgm5x8",
    "apiUrl": "https://cache.depot.dev",
    "enabled": true
  },
  "globalEnv": [
    "CI",
    "ZE_API",
    "ZE_API_GATE",
    "ZE_FAIL_BUILD",
    "ZE_IS_PREVIEW",
    "ZE_SECRET_TOKEN"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "wwwroot/**", ".output/**", "doc_build/**"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build", "^test"],
      "outputs": []
    },
    "e2e-deployment#test": {
      "cache": false,
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  },
  "ui": "tui"
}
