{
  "$schema": "https://turbo.build/schema.json",
  "remoteCache": {
    "teamSlug": "l727rgm5x8",
    "apiUrl": "https://cache.depot.dev",
    "enabled": true
  },
  "globalEnv": ["ZE_*", "ZEPHYR_*"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "lib/commonjs/**", "lib/module/**", "lib/typescript/**"],
      "inputs": [
        "$TURBO_DEFAULT$",
        "!**/*.test.ts",
        "!**/*.spec.ts",
        "!**/__test__/**",
        "!**/__tests__/**",
        "!rstest.config.ts"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "with-zephyr#test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "zephyr-agent#test": {
      "dependsOn": ["^build", "sample-webpack-application#build"],
      "outputs": ["coverage/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "e2e-test": {
      "dependsOn": ["^build"],
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "serve": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "start": {
      "cache": false,
      "persistent": true
    }
  }
}
